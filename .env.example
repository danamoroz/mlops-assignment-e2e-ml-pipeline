NEBIUS_API_KEY=XXX

# --- Deployment mode ---
# Standalone (run-airflow-standalone.sh): use host URLs below.
# Docker Compose: MLflow/S3 hostnames resolve inside the compose network.

# MLflow
# Standalone / browser on host:
MLFLOW_TRACKING_URI=http://127.0.0.1:5000
# Docker Compose (uncomment for compose-only .env):
# MLFLOW_TRACKING_URI=http://mlflow:5000

# Pipeline image for DockerOperator (build: docker build -t mlops-pipeline:latest .)
PIPELINE_IMAGE=mlops-pipeline:latest

# Docker Compose
COMPOSE_PROJECT_NAME=mlops-assignment
AIRFLOW_UID=50000
# Host docker group GID: getent group docker | cut -d: -f3
DOCKER_GID=999
AIRFLOW_PROJ_DIR=.
# Path to cloned mini-swe-agent repo (sibling of this repo by default)
MINI_SWE_AGENT_DIR=../mini-swe-agent
# Attach pipeline containers to the compose network (matches COMPOSE_PROJECT_NAME)
DOCKER_NETWORK=mlops-assignment_default

# Airflow secrets — must be identical across all Airflow containers (generate once, keep in .env)
# Fernet: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# JWT:    openssl rand -base64 32
AIRFLOW__CORE__FERNET_KEY=replace-me
AIRFLOW__API_AUTH__JWT_SECRET=replace-me

# Object storage — optional; default is local runs/ only (ARTIFACT_UPLOAD=0)
# Set ARTIFACT_UPLOAD=1 and start MinIO to upload after each DAG run.
ARTIFACT_UPLOAD=0
# Standalone MinIO on host:
S3_ENDPOINT_URL=http://127.0.0.1:9000
# Docker Compose with MinIO profile (docker compose --profile upload up):
# S3_ENDPOINT_URL=http://minio:9000
S3_BUCKET=mlops-runs
S3_PREFIX=runs
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
# For real AWS S3 or Nebius Object Storage: omit S3_ENDPOINT_URL and use platform credentials.
